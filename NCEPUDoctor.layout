#% Do not delete the line below; configure depends on this
#  \DeclareLaTeXClass[NCEPUDoctor]{NCEPU Doctor Thesis}
#  \DeclareCategory{Books}
# Author: Adapted from NCEPUMaster.layout for NCEPUDoctor.cls
#
# NCEPUDoctor.layout — LyX 布局文件
# 对应华北电力大学博士学位论文模板 NCEPUDoctor.cls
# 将 cls 中的命令和环境映射为 LyX 所见即所得样式

Format 111
Input stdclass.inc
Input numreport.inc

DocBookRoot              book
DocBookForceAbstract     true

Columns                 1
Sides                   1
PageStyle               Headers

Provides algorithm 1

# ---- 默认选项 ----
ClassOptions
	Other                 "a4paper,openany"
End

# ============================================================
#  章节样式覆盖（匹配 NCEPUMaster.cls 的 ctex 设置）
# ============================================================

Style Chapter
	LatexType             Command
	LatexName             chapterdual
	Align                 Center
	AlignPossible         Center
	Font
	  Family              Sans
	  Series              Bold
	  Size                Larger
	EndFont
	Argument 1
		LabelString       "目录标题"
		Tooltip           "目录中显示的短标题（可选）"
	EndArgument
	Argument 2
		Mandatory         1
		LabelString       "英文标题"
		Tooltip           "英文目录中显示的标题"
	EndArgument
End

Style Section
	LatexType             Command
	LatexName             sectiondual
	Align                 Left
	AlignPossible         Block, Left
	Font
	  Family              Sans
	  Series              Bold
	  Size                Large
	EndFont
	Argument 1
		LabelString       "目录标题"
		Tooltip           "目录中显示的短标题（可选）"
	EndArgument
	Argument 2
		Mandatory         1
		LabelString       "英文标题"
		Tooltip           "英文目录中显示的标题"
	EndArgument
End

Style Subsection
	LatexType             Command
	LatexName             subsectiondual
	Align                 Left
	AlignPossible         Block, Left
	Font
	  Family              Sans
	  Series              Bold
	  Size                Normal
	EndFont
	Argument 1
		LabelString       "目录标题"
		Tooltip           "目录中显示的短标题（可选）"
	EndArgument
	Argument 2
		Mandatory         1
		LabelString       "英文标题"
		Tooltip           "英文目录中显示的标题"
	EndArgument
End

Style Subsubsection
	Align                 Left
	AlignPossible         Block, Left
	Font
	  Family              Sans
	  Series              Bold
	  Size                Normal
	EndFont
End

Style Paragraph
	TopSep                0.7
	ParSep                0.4
	Font
	  Family              Sans
	  Series              Bold
	  Shape               Italic
	  Size                Normal
	EndFont
End

Style Chapter*
	Align                 Center
	AlignPossible         Center
End

NoStyle Subparagraph*

# ============================================================
#  章节结构样式
# ============================================================

# ---- 无编号章节（带目录条目）----
Style ChapterStar
	Margin                Static
	LatexType             Command
	LatexName             chapterstartdual
	Category              Unnumbered
	LabelType             No_Label
	Align                 Center
	AlignPossible         Center
	Font
	  Family              Sans
	  Series              Bold
	  Size                Larger
	EndFont
	Argument 1
		LabelString       "目录标题"
		Tooltip           "目录中显示的短标题（可选）"
	EndArgument
	Argument 2
		Mandatory         1
		LabelString       "英文标题"
		Tooltip           "英文目录中显示的标题"
	EndArgument
End

# ---- 目录 ----
Style Contents
	Margin                Static
	LatexType             Command
	LatexName             contents
	Category              FrontMatter
	InTitle               0
	KeepEmpty             0
	TopSep                0
	BottomSep             0
	Align                 Center
	LabelType             No_Label
End

# ---- 图表清单 ----
Style ListOfFigsAndTables
	Margin                Static
	LatexType             Command
	LatexName             listoffiguresandtables
	Category              FrontMatter
	InTitle               0
	KeepEmpty             0
	TopSep                0
	BottomSep             0
	Align                 Center
	LabelType             No_Label
End

# ---- 附录开始 ----
Style AppendixStart
	Margin                Static
	LatexType             Command
	LatexName             startappendix
	Category              BackMatter
	InTitle               0
	KeepEmpty             0
	TopSep                0.5
	BottomSep             0
	Align                 Center
	LabelType             No_Label
	Font
	  Family              Sans
	  Series              Bold
	  Size                Normal
	EndFont
	LabelFont
	  Family              Sans
	  Series              Bold
	  Size                Normal
	EndFont
End

# ---- 附录结束 ----
Style AppendixStop
	CopyStyle             AppendixStart
	LatexName             stopappendix
End

# ============================================================
#  中英文摘要环境
# ============================================================

# ---- 中文关键词 ----
Style KeywordsZH
	Margin                First_Dynamic
	LatexType             Command
	LatexName             lyxzhkeywords
	InTitle               0
	LabelSep              xx
	ParSkip               0.4
	TopSep                0.3
	BottomSep             0.3
	Align                 Center
	LabelType             Static
	LabelString           "关键词："
	LabelFont
	  Series              Bold
	  Size                Normal
	EndFont
	Font
	  Family              Roman
	  Series              Medium
	  Size                Normal
	EndFont
End

# ---- 英文关键词 ----
Style KeywordsEN
	CopyStyle             KeywordsZH
	LatexName             lyxenkeywords
	LabelString           "Keywords:"
End

# ---- 中文摘要 ----
Style AbstractZH
	Margin                Static
	LatexType             Environment
	LatexName             lyxabstractzh
	Category              FrontMatter
	InTitle               0
	NextNoIndent          1
	LeftMargin            MMM
	RightMargin           MMM
	ParIndent             MM
	ItemSep               0.2
	ParSep                0.3
	TopSep                0.7
	BottomSep             0.7
	Align                 Block
	LabelType             No_Label
	Font
	  Family              Roman
	  Series              Medium
	  Shape               Up
	  Size                Normal
	EndFont
End

# ---- 英文摘要 ----
Style AbstractEN
	CopyStyle             AbstractZH
	LatexName             lyxabstracten
End

# ============================================================
#  元数据样式（用户在 LyX 中直接填写，编译时自动代入封面和信息页）
# ============================================================

# --- 学位类型（学术硕士 / 专业硕士）---
Style DoctorType
	Margin                Static
	LatexType             Command
	LatexName             degreetype
	Category              基本信息
	InTitle               1
	LabelSep              xx
	ParSkip               0.4
	TopSep                0.8
	BottomSep             0.4
	Align                 Center
	LabelType             Static
	LabelString           "学位类型 (academic/professional)："
	LabelFont
	  Series              Bold
	  Size                Normal
	EndFont
	Font
	  Family              Roman
	  Series              Medium
	  Size                Normal
	EndFont
End

# ========== 基本信息（公共字段）==========

# --- 中文论文标题 ---
Style TitleZH
	Margin                Static
	LatexType             Command
	LatexName             ctitlezh
	Category              基本信息
	InTitle               1
	LabelSep              xx
	ParSkip               0.4
	TopSep                0.8
	BottomSep             0.4
	ParSep                0.7
	Align                 Center
	LabelType             Static
	LabelString           "中文标题："
	LabelFont
	  Series              Bold
	  Size                Normal
	EndFont
	Font
	  Family              Sans
	  Series              Bold
	  Size                Normal
	EndFont
End

# --- 英文论文标题 ---
Style TitleEN
	CopyStyle             TitleZH
	LatexName             ctitleen
	LabelString           "英文标题："
End

# --- 英文标题过长标志 ---
Style TitleENLong
	CopyStyle             TitleZH
	LatexName             Ltitle
	LabelString           "英文标题过长(True/False)："
	Font
	  Family              Roman
	  Series              Medium
	  Size                Normal
	EndFont
End

# --- 中文作者 ---
Style AuthorZH
	CopyStyle             TitleZH
	LatexName             cauthorzh
	LabelString           "中文作者："
	Font
	  Family              Roman
	  Series              Medium
	  Size                Normal
	EndFont
	Align                 Center
End

# --- 英文作者 ---
Style AuthorEN
	CopyStyle             AuthorZH
	LatexName             cauthoren
	LabelString           "英文作者："
End

# --- 中文导师 ---
Style AdvisorZH
	CopyStyle             AuthorZH
	LatexName             cadvisorzh
	LabelString           "中文导师："
End

# --- 英文导师 ---
Style AdvisorEN
	CopyStyle             AuthorZH
	LatexName             cadvisoren
	LabelString           "英文导师："
End

# --- 中文申请学位（学硕/专硕名称不同）---
Style DegreeZH
	CopyStyle             AuthorZH
	LatexName             cdegreezh
	LabelString           "中文申请学位（学博→工学博士，专博→工程博士）："
End

# --- 英文申请学位 ---
Style DegreeEN
	CopyStyle             AuthorZH
	LatexName             cdegreeen
	LabelString           "英文申请学位："
End
# --- 英文联合导师（学术博士）---
Style CoSupervisorEN
	CopyStyle             AuthorZH
	LatexName             ccosupervisoren
	Category              学术博士专用
	LabelString           "[学博] 英文联合导师："
End
# --- 英文联合导师（学术博士）---
Style CoSupervisorEN
	CopyStyle             AuthorZH
	LatexName             ccosupervisoren
	Category              学术博士专用
	LabelString           "[学博] 英文联合导师："
End

# --- 英文联合导师（学术博士）---
Style CoSupervisorEN
	CopyStyle             AuthorZH
	LatexName             ccosupervisoren
	Category              学术博士专用
	LabelString           "[学博] 英文联合导师："
End


# --- 英文联合导师（学术博士）---
