# ========== 其他信息 ==========

# --- 国内图书分类号 ---
Style CLC
	CopyStyle             AuthorZH
	LatexName             cclc
	Category              其他信息
	LabelString           "国内图书分类号："
End

# --- 国际图书分类号 ---
Style UDC
	CopyStyle             AuthorZH
	LatexName             cudc
	Category              其他信息
	LabelString           "国际图书分类号："
End

# --- 密级 ---
Style SecretLevel
	CopyStyle             AuthorZH
	LatexName             csecretlevel
	Category              其他信息
	LabelString           "密级(public/internal/secret/confidential/topsecret)："
End

# ============================================================
#  定理环境（使用 ntheorem，编号按节）
# ============================================================

Style Theorem
	LatexType             Environment
	LatexName             theorem
	Margin                First_Dynamic
	TopSep                0.6
	BottomSep             0.6
	Align                 Block
	NextNoIndent          1
	LabelType             Static
	LabelString           "定理 \thetheorem"
	LabelSep              M
	LabelFont
	  Family              Sans
	  Series              Bold
	  Shape               Up
	EndFont
	TextFont
	  Shape               Italic
	EndFont
	Argument 1
	  LabelString "简短说明"
	  Tooltip "定理的补充说明"
	EndArgument
End

Style Definition
	CopyStyle             Theorem
	LatexName             definition
	LabelString           "定义 \thedefinition"
	TextFont
	  Shape               Up
	EndFont
	Argument 1
	  LabelString "简短说明"
	  Tooltip "定义的补充说明"
	EndArgument
End

Style Lemma
	CopyStyle             Theorem
	LatexName             lemma
	LabelString           "引理 \thelemma"
	Argument 1
	  LabelString "简短说明"
	  Tooltip "定理的补充说明"
	EndArgument
End

Style Corollary
	CopyStyle             Theorem
	LatexName             corollary
	LabelString           "推论 \thecorollary"
	Argument 1
	  LabelString "简短说明"
	  Tooltip "定理的补充说明"
	EndArgument
End

Style Proposition
	CopyStyle             Theorem
	LatexName             proposition
	LabelString           "性质 \theproposition"
	Argument 1
	  LabelString "简短说明"
	  Tooltip "定理的补充说明"
	EndArgument
End

Style Example
	CopyStyle             Definition
	LatexName             example
	LabelString           "例 \theexample"
	Argument 1
	  LabelString "简短说明"
	  Tooltip "定义的补充说明"
	EndArgument
End

Style Remark
	CopyStyle             Definition
	LatexName             remark
	LabelString           "注 \theremark"
	Argument 1
	  LabelString "简短说明"
	  Tooltip "定义的补充说明"
	EndArgument
End

Style Proof
	LatexType             Environment
	LatexName             proof
	Margin                First_Dynamic
	TopSep                0.6
	BottomSep             0.6
	Align                 Block
	NextNoIndent          1
	LabelType              Static
	LabelString           "证明"
	LabelSep              M
	LabelFont
	  Family              Sans
	  Series              Bold
	  Shape               Up
	EndFont
	TextFont
	  Shape               Up
	EndFont
	EndLabelType          Box
End

# ============================================================
#  特殊环境
# ============================================================

# ---- 加粗段落（首段，段后0.5行）----
Style BoldParaFirst
	Margin                Static
	LatexType             Command
	LatexName             boldparafirst
	Category              Unnumbered
	InTitle               0
	ParSkip               0.4
	TopSep                0.7
	BottomSep             0.3
	ParSep                0
	Align                 Block
	AlignPossible         Block, Left
	LabelType             No_Label
	Font
	  Family              Roman
	  Series              Bold
	  Shape               Up
	  Size                Normal
	EndFont
End

# ---- 加粗段落（非首段，段前段后各0.5行）----
Style BoldPara
	CopyStyle             BoldParaFirst
	LatexName             boldpara
	TopSep                0.5
	BottomSep             0.5
End

# ============================================================
#  图表双语标题样式
# ============================================================

# ---- 图双语标题 ----
Style BilingualFigureCaption
	Margin                Static
	LatexType             Command
	LatexName             figcaptioncneng
	Category              Float
	InTitle               0
	ParSkip               0.4
	TopSep                0.3
	BottomSep             0.3
	Align                 Center
	LabelType             No_Label
	Font
	  Family              Roman
	  Series              Medium
	  Size                Normal
	EndFont
End

# ---- 子图双语标题 ----
Style BilingualSubfigCaption
	CopyStyle             BilingualFigureCaption
	LatexName             subfigcaptioncneng
End

# ---- 表双语标题 ----
Style BilingualTableCaption
	CopyStyle             BilingualFigureCaption
	LatexName             bilingualtablecaption
End

# ============================================================
#  子图 Flex Inset（代替 \begin{subfigure}...\end{subfigure} ERT）
# ============================================================

InsetLayout Flex:Subfigure
	LyxType               custom
	LatexType             environment
	LatexName             lyxsubfigure
	Decoration            classic
	LabelString           "子图"
	MultiPar              true
	Argument 1
		LabelString       "位置[t/b]"
		Tooltip           "可选位置参数: t=顶部对齐, b=底部对齐 (默认为 t)"
	EndArgument
	Argument 2
		Mandatory         1
		LabelString       "宽度倍率"
		Tooltip           "宽度比例系数 (最终宽度 = 倍率 × \\textwidth)"
	EndArgument
End

# ============================================================
#  算法伪代码样式（替代 algorithmic ERT）
#  使用 LatexType Command，配合 preamble 中的命令重定义
#  每个段落生成一个算法命令，嵌套由命令序列隐式维护
# ============================================================

# ---- 算法参数（PassThru 避免 $ 等特殊字符被转义）----
Style AlgArg
	Margin                Static
	LatexType             Paragraph
	PassThru              1
	KeepEmpty             1
	ParSkip               0
	TopSep                0
	BottomSep             0
	Align                 Block
	LabelType             No_Label
	Font
	  Family              Roman
	  Series              Medium
	  Shape               Up
	  Size                Normal
	EndFont
End

Style AlgorithmicBegin
	LatexType             Command
	LatexName             algpseudobegin
	Margin                Static
	LeftMargin            MMM
	ParSkip               0
	TopSep                0.1
	BottomSep             0
	Align                 Block
	LabelType             No_Label
	KeepEmpty             1
	Font
	  Family              Roman
	  Series              Medium
	  Shape               Up
	  Size                Normal
	EndFont
PassThru              1
End

Style AlgorithmicEnd
	LatexType             Command
	LatexName             algpseudoend
	Margin                Static
	LeftMargin            MMM
	ParSkip               0
	TopSep                0
	BottomSep             0.1
	Align                 Block
	LabelType             No_Label
	KeepEmpty             1
	Font
	  Family              Roman
	  Series              Medium
	  Shape               Up
	  Size                Normal
	EndFont
	PassThru              1
End

Style AlgState
	LatexType             Command
	LatexName             algstateinner
	Margin                Static
	LeftMargin            MMM
	ParSkip               0.2
	TopSep                0.1
	BottomSep             0.1
	Align                 Block
	LabelType             No_Label
	Font
	  Family              Roman
	  Series              Medium
	  Shape               Up
	  Size                Normal
	EndFont
PassThru              1
End

Style AlgFor
	LatexType             Command
	LatexName             FOR
	Margin                Static
	LeftMargin            MM
	ParSkip               0.2
	TopSep                0.1
	BottomSep             0.1
	Align                 Block
	LabelType             No_Label
	Argument 1
		LabelString       "循环条件"
		Tooltip           "FOR 循环的条件表达式"
		Mandatory         1
	EndArgument
	Font
	  Family              Sans
	  Series              Bold
	  Shape               Up
	  Size                Normal
	EndFont
	KeepEmpty             1
PassThru              1
End

Style AlgEndFor
	LatexType             Command
